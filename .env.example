# Application
APP_NAME=ETBP
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_PREFIX=/api

# Database
DATABASE_URL=postgresql+asyncpg://etbp:etbp_secret@localhost:5432/etbp
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Termii (SMS)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=ETBP

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=etbp-uploads
AWS_SES_SENDER_EMAIL=noreply@etbp.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Superadmin seed
SUPERADMIN_EMAIL=admin@etbp.com
SUPERADMIN_PASSWORD=change-me
